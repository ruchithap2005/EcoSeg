```gitignore
# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# VS Code
.vscode/

# PyCharm
.idea/

# Environment variables
.env

# Database
*.db
*.sqlite3

# Logs
logs/
*.log

# TensorBoard logs
events.out.tfevents.*

# Uploaded images (keep folder, ignore contents)
static/uploads/*

# OS files
.DS_Store
Thumbs.db

# Python build files
build/
dist/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints/

# Temporary files
*.tmp
*.temp
```
